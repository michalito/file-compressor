SECRET_KEY=your-very-long-random-secret-key
APP_PASSWORD=your-secure-password

# Optional per-IP processing burst limit for large batches
# PROCESS_RATE_LIMIT=120 per minute

# Optional AI upscaling integration (Docker Compose CPU worker)
# AI_UPSCALER_ENABLED=false
# AI_UPSCALER_URL=http://upscaler:8765
# AI_UPSCALER_API_KEY=
# AI_UPSCALE_MAX_OUTPUT_DIMENSION=12000
# AI_UPSCALE_MAX_OUTPUT_PIXELS=100000000
# AI_UPSCALE_ARTIFACT_TTL_SECONDS=21600

# CPU worker options
# AI_UPSCALER_BACKEND=torch-cpu
# AI_UPSCALER_MODEL_CACHE_DIR=/models
# AI_UPSCALER_AUTO_DOWNLOAD_MODELS=true
# AI_UPSCALER_PRELOAD_MODELS=false
# AI_UPSCALER_MODEL_CACHE_SIZE=1
# AI_UPSCALER_CPU_THREADS=0
# AI_UPSCALER_INTEROP_THREADS=1
# AI_UPSCALER_MEMORY_LIMIT_BYTES=0
# AI_UPSCALER_MEMORY_TARGET_PERCENT=0.75
# AI_UPSCALER_MEMORY_RESERVED_BYTES=805306368
# AI_UPSCALER_MAX_UPLOAD_BYTES=52428800
# AI_UPSCALER_WORK_ROOT=/tmp/compressify-upscaler
# AI_UPSCALER_MAX_WORKERS=1
# AI_UPSCALER_CONTAINER_MEMORY_LIMIT=6g

# Dokploy image references (set these in Dokploy, not local Docker Compose)
# WEB_IMAGE=ghcr.io/<owner>/file-compressor-web:latest
# UPSCALER_IMAGE=ghcr.io/<owner>/file-compressor-upscaler:latest
